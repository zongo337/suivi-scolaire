<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Autorise le trafic HTTP (non chiffré) UNIQUEMENT vers les adresses
      de développement local, pour pouvoir tester l'application contre
      "php artisan serve" sans certificat SSL.

      - 10.0.2.2 : alias de la machine hôte depuis l'émulateur Android Studio
      - localhost / 127.0.0.1 : test sur le même appareil

      Pour tester depuis un téléphone physique sur le même réseau Wi-Fi
      que votre ordinateur, ajoutez une ligne <domain> avec l'adresse IP
      locale de votre machine (visible via "ipconfig" / "ifconfig"),
      par exemple : <domain includeSubdomains="false">192.168.1.20</domain>

      ⚠️ En production, configurez l'API derrière HTTPS et supprimez ce
      fichier ainsi que la référence android:networkSecurityConfig dans
      le manifeste.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.231.54.182</domain>
    </domain-config>

    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
