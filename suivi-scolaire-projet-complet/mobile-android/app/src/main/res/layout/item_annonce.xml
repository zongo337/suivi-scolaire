<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/badgeTypeAnnonce"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_info"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/blue"
            android:text="Annonce" />

        <TextView
            android:id="@+id/badgeClasseAnnonce"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:text="Toute l'école" />

        <TextView
            android:id="@+id/textViewDateAnnonce"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:text="Date" />
    </LinearLayout>

    <TextView
        android:id="@+id/textViewTitreAnnonce"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:text="Titre de l'annonce" />

    <TextView
        android:id="@+id/textViewContenuAnnonce"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="13.5sp"
        android:textColor="@color/text_secondary"
        android:text="Contenu de l'annonce..." />

</LinearLayout>
